<Window x:Class="Wrish.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wrish - 未命名"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="900" 
        Height="600"
        MinWidth="400" 
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        SizeChanged="Window_SizeChanged">

    <Border x:Name="MainBorder" 
            Background="#1E1E1E" 
            BorderThickness="1" 
            BorderBrush="#333333">
        <Grid>
            <ScrollViewer x:Name="EditorScroll"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- 上半 Padding：让第一行也能滚动到屏幕中央 -->
                    <Border x:Name="TopPadding"
                            Height="0"
                            Background="Transparent"/>
                    <RichTextBox x:Name="Editor"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#D4D4D4"
                                 FontFamily="Microsoft YaHei, Consolas, monospace"
                                 FontSize="18"
                                 VerticalScrollBarVisibility="Hidden"
                                 HorizontalScrollBarVisibility="Disabled"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 SelectionBrush="#264F78"
                                 CaretBrush="#D4D4D4"
                                 IsInactiveSelectionHighlightEnabled="True"
                                 PreviewKeyDown="Editor_PreviewKeyDown"
                                 PreviewMouseWheel="Editor_PreviewMouseWheel"
                                 TextChanged="Editor_TextChanged"
                                 SelectionChanged="Editor_SelectionChanged"/>
                    <!-- 下半 Padding：让最后一行也能滚动到屏幕中央 -->
                    <Border x:Name="BottomPadding"
                            Height="0"
                            Background="Transparent"/>
                </StackPanel>
            </ScrollViewer>

            <TextBlock x:Name="WordCountText"
                       Text="0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,20,10"
                       Foreground="#D4D4D4"
                       Opacity="0.08"
                       FontSize="12"
                       IsHitTestVisible="False"/>
        </Grid>
    </Border>
</Window>